{
  "log_level": "INFO",
  "robot": {
    "system": "pebble",
    "type": "robots",
    "id": "my-robot"
  },
  "local_mqtt": {
    "host": "127.0.0.1",
    "port": 1883,
    "keepalive": 60,
    "username": "",
    "password": "",
    "tls": {
      "enabled": false,
      "ca_cert": "",
      "client_cert": "",
      "client_key": "",
      "insecure": false,
      "ciphers": ""
    }
  },
  "services": {
    "defaults": {
      "retained_publish_interval_seconds": 3600
    },
    "launcher": {
      "enabled": true,
      "restart_delay_seconds": 2.0,
      "shutdown_timeout_seconds": 8.0,
      "log_level": "INFO",
      "capabilities": {
        "enabled": true,
        "topic": "pebble/robots/my-robot/outgoing/capabilities",
        "qos": 1,
        "retain": true,
        "publish_interval_seconds": 3600
      },
      "logs": {
        "enabled": true,
        "topic": "pebble/robots/my-robot/outgoing/logs",
        "qos": 0,
        "retain": false,
        "min_level": "INFO",
        "max_message_chars": 2048
      }
    },
    "av_daemon": {
      "enabled": true,
      "log_level": "INFO",
      "restart_delay_seconds": 2.0,
      "stop_timeout_seconds": 5.0,
      "cwd": "../..",
      "env": {},
      "video": {
        "enabled": true,
        "backend": "v4l2",
        "capture_format": "auto",
        "device": "/dev/video0",
        "io_mode": "auto",
        "camera_name": "",
        "camera_controls": {},
        "width": 640,
        "height": 480,
        "fps": 15,
        "rotate_degrees": 0,
        "socket_path": "/tmp/pebble-video.sock",
        "shm_size": 16777216,
        "wait_for_connection": false
      },
      "audio": {
        "enabled": true,
        "source": "alsa",
        "device": "default",
        "rate": 16000,
        "channels": 1,
        "socket_path": "/tmp/pebble-audio.sock",
        "shm_size": 524288,
        "wait_for_connection": false
      }
    },
    "mqtt_bridge": {
      "enabled": true,
      "log_level": "INFO",
      "remote_mqtt": {
        "host": "",
        "port": 1883,
        "keepalive": 60,
        "username": "",
        "password": "",
        "tls": {
          "enabled": false,
          "ca_cert": "",
          "client_cert": "",
          "client_key": "",
          "insecure": false,
          "ciphers": ""
        }
      },
      "topics": {
        "remote_mirror": "pebble/robots/my-robot/incoming/flags/remote-mirror",
        "mqtt_audio": "pebble/robots/my-robot/incoming/flags/mqtt-audio",
        "mqtt_video": "pebble/robots/my-robot/incoming/flags/mqtt-video",
        "reboot": "pebble/robots/my-robot/incoming/flags/reboot",
        "git_pull": "pebble/robots/my-robot/incoming/flags/git-pull",
        "audio_control": "pebble/robots/my-robot/incoming/audio",
        "video_control": "pebble/robots/my-robot/incoming/front-camera"
      },
      "heartbeat": {
        "enabled": true,
        "topic": "pebble/robots/my-robot/outgoing/online",
        "interval_seconds": 0.25,
        "qos": 1,
        "retain": true
      },
      "media": {
        "video_publisher": {
          "profile": "default",
          "topic": "pebble/robots/my-robot/outgoing/front-camera",
          "input_shm": "/tmp/pebble-video.sock",
          "input_retry_seconds": 2.0,
          "width": 640,
          "height": 480,
          "fps": 15,
          "publish_width": 640,
          "publish_height": 480,
          "publish_fps": 15,
          "target_fps": 15,
          "keyframe_interval": 5,
          "jpeg_quality": 10,
          "rotate_degrees": 0,
          "reconnect_seconds": 10
        },
        "audio_publisher": {
          "topic": "pebble/robots/my-robot/outgoing/audio",
          "input_shm": "/tmp/pebble-audio.sock",
          "input_retry_seconds": 2.0,
          "rate": 16000,
          "channels": 1,
          "chunk_ms": 20,
          "qos": 0
        },
        "audio_receiver": {
          "topic": "pebble/robots/my-robot/incoming/audio-stream",
          "device": "default",
          "rate": 16000,
          "channels": 1,
          "queue_limit": 48,
          "concealment_ms": 100,
          "qos": 0
        }
      },
      "video_control": {
        "command": [
          "python3",
          "video/camera_publisher.py",
          "--config",
          "control/configs/config.json"
        ],
        "cwd": "../..",
        "stop_timeout": 8,
        "env": {}
      },
      "audio_control": {
        "publisher_command": [
          "python3",
          "audio/audio_publisher.py",
          "--config",
          "control/configs/config.json"
        ],
        "publisher_cwd": "../..",
        "receiver_command": [
          "python3",
          "audio/audio_receiver.py",
          "--config",
          "control/configs/config.json"
        ],
        "receiver_cwd": "../..",
        "stop_timeout": 8,
        "env": {}
      },
      "reboot_control": {
        "command": ["sudo", "-n", "/sbin/reboot"],
        "cwd": "",
        "cooldown_seconds": 30,
        "ignore_retained": true,
        "env": {}
      },
      "git_pull_control": {
        "command": ["git", "-C", "/opt/pebble", "pull", "--ff-only"],
        "cwd": "",
        "cooldown_seconds": 60,
        "ignore_retained": true,
        "env": {}
      }
    },
    "ros1_bridge": {
      "enabled": false,
      "log_level": "INFO",
      "topics": {
        "drive_values": "pebble/robots/my-robot/incoming/drive-values",
        "wheel_odometry": "pebble/robots/my-robot/outgoing/wheel-odometry",
        "charging_status": "pebble/robots/my-robot/outgoing/charging-status",
        "charging_level": "pebble/robots/my-robot/outgoing/charging-level",
        "localization_pose": "pebble/robots/my-robot/outgoing/localization-pose",
        "navigation_status": "pebble/robots/my-robot/outgoing/navigation-status",
        "navigation_goal": "pebble/robots/my-robot/outgoing/navigation-goal",
        "navigation_local_plan": "pebble/robots/my-robot/outgoing/navigation/local-plan",
        "navigation_global_plan": "pebble/robots/my-robot/outgoing/navigation/global-plan",
        "diagnostics": "pebble/robots/my-robot/outgoing/diagnostics"
      },
      "heartbeat": {
        "enabled": true,
        "topic": "pebble/robots/my-robot/outgoing/online",
        "interval_seconds": 0.25,
        "qos": 1,
        "retain": true
      },
      "ros": {
        "node_name": "pebble_ros1_bridge",
        "cmd_vel_topic": "/cmd_vel",
        "cmd_vel_publish_interval_seconds": 0.05,
        "odometry_topic": "/odometry/filtered",
        "navigation_status_topic": "/move_base/status",
        "navigation_goal_topic": "/move_base/current_goal",
        "navigation_local_plan_topic": "/move_base/TrajectoryPlannerROS/local_plan",
        "navigation_global_plan_topic": "/move_base/NavfnROS/plan",
        "diagnostics_topic": "/diagnostics_agg"
      },
      "motion": {
        "max_linear_speed_mps": 0.6,
        "max_angular_speed_radps": 1.2
      },
      "telemetry": {
        "wheel_odometry": {
          "enabled": true,
          "interval_seconds": 0.25,
          "qos": 0,
          "retain": false
        },
        "localization_pose": {
          "enabled": true,
          "interval_seconds": 0.25,
          "qos": 0,
          "retain": false
        },
        "navigation_status": {
          "enabled": true,
          "interval_seconds": 0.5,
          "qos": 1,
          "retain": true
        },
        "navigation_goal": {
          "enabled": true,
          "qos": 1,
          "retain": true
        },
        "navigation_local_plan": {
          "enabled": false,
          "interval_seconds": 1.0,
          "qos": 0,
          "retain": false,
          "max_points": 40
        },
        "navigation_global_plan": {
          "enabled": false,
          "interval_seconds": 1.0,
          "qos": 0,
          "retain": false,
          "max_points": 60
        },
        "diagnostics": {
          "enabled": true,
          "interval_seconds": 1.0,
          "qos": 1,
          "retain": true,
          "max_items": 8
        },
        "charging_level": {
          "enabled": true,
          "qos": 1,
          "retain": true,
          "status_name": "/Jackal Base/General/Battery",
          "key": "Battery Voltage (V)"
        },
        "charging_status": {
          "enabled": false,
          "qos": 1,
          "retain": true,
          "status_name": "",
          "key": "",
          "truthy_values": ["true", "charging", "yes", "1"],
          "falsey_values": ["false", "not charging", "no", "0"]
        }
      },
      "safety": {
        "drive_timeout_seconds": 0.75,
        "ignore_retained_drive": true,
        "stop_on_shutdown": true
      }
    },
    "serial_mcu_bridge": {
      "enabled": true,
      "log_level": "INFO",
      "retained_publish_interval_seconds": 3600,
      "serial": {
        "port": "/dev/ttyACM0",
        "baud": 115200,
        "timeout_seconds": 0.1
      },
      "telemetry": {
        "publish_touch_sensors": false
      },
      "odometry_shm": {
        "enabled": true,
        "name": "pebble_robots_my-robot_odometry_raw",
        "slots": 2048
      },
      "safety": {
        "drive_timeout_seconds": 0.75,
        "ignore_retained_drive": true,
        "stop_on_shutdown": true
      },
      "topics": {
        "drive_values": "pebble/robots/my-robot/incoming/drive-values",
        "lights_solid": "pebble/robots/my-robot/incoming/lights-solid",
        "lights_flash": "pebble/robots/my-robot/incoming/lights-flash",
        "touch_sensors": "pebble/robots/my-robot/outgoing/touch-sensors",
        "charging_status": "pebble/robots/my-robot/outgoing/charging-status"
      }
    },
    "soundboard_handler": {
      "enabled": true,
      "log_level": "INFO",
      "topics": {
        "command": "pebble/robots/my-robot/incoming/soundboard-command",
        "files": "pebble/robots/my-robot/outgoing/soundboard-files",
        "status": "pebble/robots/my-robot/outgoing/soundboard-status"
      },
      "playback": {
        "directory": "/var/lib/pebble/sounds",
        "player_command": ["aplay"],
        "stop_timeout": 5,
        "scan_interval": 10,
        "cwd": "",
        "env": {}
      }
    },
    "autonomy_manager": {
      "enabled": true,
      "log_level": "INFO",
      "autonomy_root": "autonomy",
      "scan_interval_seconds": 5,
      "stop_timeout_seconds": 8,
      "topics": {
        "command": "pebble/robots/my-robot/incoming/autonomy-command",
        "files": "pebble/robots/my-robot/outgoing/autonomy-files",
        "status": "pebble/robots/my-robot/outgoing/autonomy-status"
      },
      "scripts": {
        "apriltag-follow": {
          "enabled": true,
          "display_name": "AprilTag Follow",
          "entrypoint": "run.py",
          "cwd": "",
          "env": {},
          "args": [
            {
              "key": "tag_id",
              "label": "Tag ID",
              "type": "int",
              "default": 13,
              "arg": "--marker-id",
              "min": 0
            },
            {
              "key": "tag_size_m",
              "label": "Tag Size (m)",
              "type": "float",
              "default": 0.25,
              "arg": "--marker-size",
              "min": 0.01,
              "required": true
            },
            {
              "key": "target_distance_m",
              "label": "Target Distance (m)",
              "type": "float",
              "default": 0.6,
              "arg": "--target-distance",
              "min": 0.05
            },
            {
              "key": "control_rate_hz",
              "label": "Control Rate (Hz)",
              "type": "float",
              "default": 10.0,
              "arg": "--rate",
              "min": 1.0
            },
            {
              "key": "turn_power",
              "label": "Turn Power",
              "type": "float",
              "default": 0.5,
              "arg": "--turn-power",
              "min": 0.05,
              "max": 1.0
            },
            {
              "key": "search_pause_s",
              "label": "Search Pause (s)",
              "type": "float",
              "default": 0.2,
              "arg": "--search-pause",
              "min": 0.0
            },
            {
              "key": "search_reverse_after_s",
              "label": "Search Reverse After (s)",
              "type": "float",
              "default": 0.0,
              "arg": "--search-reverse-after",
              "min": 0.0
            },
            {
              "key": "preview",
              "label": "Preview Window",
              "type": "bool",
              "default": false,
              "arg": "--preview",
              "mode": "flag"
            }
          ]
        },
        "apriltag-odom-follow": {
          "enabled": true,
          "display_name": "AprilTag Odom Follow",
          "entrypoint": "run.py",
          "cwd": "",
          "env": {},
          "args": [
            {
              "key": "tag_id",
              "label": "Tag ID",
              "type": "int",
              "default": 13,
              "arg": "--marker-id",
              "min": 0
            },
            {
              "key": "tag_size_m",
              "label": "Tag Size (m)",
              "type": "float",
              "default": 0.25,
              "arg": "--marker-size",
              "min": 0.01,
              "required": true
            },
            {
              "key": "target_distance_m",
              "label": "Target Distance (m)",
              "type": "float",
              "default": 0.6,
              "arg": "--target-distance",
              "min": 0.05
            },
            {
              "key": "control_rate_hz",
              "label": "Control Rate (Hz)",
              "type": "float",
              "default": 10.0,
              "arg": "--rate",
              "min": 1.0
            },
            {
              "key": "turn_power",
              "label": "Turn Power",
              "type": "float",
              "default": 0.5,
              "arg": "--turn-power",
              "min": 0.05,
              "max": 1.0
            },
            {
              "key": "turn_pulse_s",
              "label": "Turn Pulse (s)",
              "type": "float",
              "default": 0.08,
              "arg": "--turn-pulse",
              "min": 0.02
            },
            {
              "key": "turn_cooldown_s",
              "label": "Turn Cooldown (s)",
              "type": "float",
              "default": 0.18,
              "arg": "--turn-cooldown",
              "min": 0.0
            },
            {
              "key": "odom_goal_tolerance_m",
              "label": "Odom Goal Tolerance (m)",
              "type": "float",
              "default": 0.06,
              "arg": "--odom-goal-tolerance-m",
              "min": 0.01
            },
            {
              "key": "odom_heading_kp",
              "label": "Odom Heading Kp",
              "type": "float",
              "default": 1.5,
              "arg": "--odom-heading-kp",
              "min": 0.1
            },
            {
              "key": "odom_distance_kp",
              "label": "Odom Distance Kp",
              "type": "float",
              "default": 1.4,
              "arg": "--odom-distance-kp",
              "min": 0.1
            },
            {
              "key": "search_pause_s",
              "label": "Search Pause (s)",
              "type": "float",
              "default": 0.35,
              "arg": "--search-pause",
              "min": 0.0
            },
            {
              "key": "search_reverse_after_s",
              "label": "Search Reverse After (s)",
              "type": "float",
              "default": 0.0,
              "arg": "--search-reverse-after",
              "min": 0.0
            },
            {
              "key": "lost_timeout_s",
              "label": "Lost Timeout (s)",
              "type": "float",
              "default": 0.2,
              "arg": "--lost-timeout",
              "min": 0.0
            },
            {
              "key": "log_file",
              "label": "Log File",
              "type": "string",
              "default": "",
              "arg": "--log-file"
            },
            {
              "key": "preview",
              "label": "Preview Window",
              "type": "bool",
              "default": false,
              "arg": "--preview",
              "mode": "flag"
            }
          ]
        }
      }
    }
  },
  "web_interface": {
    "log_level": "INFO",
    "robot_discovery": {
      "seed_configured": true
    },
    "mqtt": {
      "host": "127.0.0.1",
      "port": 1883,
      "keepalive": 60,
      "username": "",
      "password": "",
      "tls": {
        "enabled": false,
        "ca_cert": "",
        "client_cert": "",
        "client_key": "",
        "insecure": false,
        "ciphers": ""
      }
    },
    "mqtt_history": {
      "enabled": false,
      "uri": "mongodb://127.0.0.1:27017",
      "database": "pebble",
      "collection": "mqtt_history",
      "max_bytes": 536870912000,
      "subscribe_all_topics": true,
      "prune_check_every_messages": 2000,
      "prune_chunk_documents": 50000,
      "prune_target_ratio": 0.9
    },
    "robots": [
      {
        "id": "my-robot",
        "name": "My Robot",
        "type": "robots",
        "video": {
          "topic": "pebble/robots/my-robot/outgoing/front-camera",
          "controls": true
        },
        "audio": {
          "topic": "pebble/robots/my-robot/outgoing/audio",
          "uplink_topic": "pebble/robots/my-robot/incoming/audio-stream",
          "rate": 16000,
          "channels": 1,
          "chunk_ms": 20,
          "concealment_ms": 100,
          "controls": true
        },
        "reboot": {
          "controls": true
        }
      }
    ]
  }
}
