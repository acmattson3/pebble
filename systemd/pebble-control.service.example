[Unit]
Description=Pebble Control Launcher
After=network-online.target mosquitto.service
Wants=network-online.target

[Service]
Type=simple
User=pebble
Group=pebble
WorkingDirectory=/opt/pebble
ExecStart=/usr/bin/python3 /opt/pebble/control/launcher.py --config /opt/pebble/control/configs/config.json
Restart=on-failure
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
